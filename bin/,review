#!/usr/bin/env bash
set -e

if [ -z "$1" ]; then
    echo "Usage: ,review <gitlab-merge-request-url>"
    exit 1
fi

# Create/find worktree (stdout: line1=path, line2=target_branch)
output=$(~/bin/git-mr-worktree.sh "$1")
worktree_path=$(echo "$output" | sed -n '1p')
target_branch=$(echo "$output" | sed -n '2p')

cd "$worktree_path"
echo "✓ Changed to worktree: $worktree_path"

echo "Starting review with pi..."
pi "/review branch $target_branch"
