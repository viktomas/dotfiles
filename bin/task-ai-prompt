#!/bin/bash
# Called from zellij keybinding to create a task via task-ai
# Runs in a floating pane that closes on exit
printf "New task: "
read -r input
if [ -n "$input" ]; then
    # Escape single quotes for fish
    escaped=$(printf '%s' "$input" | sed "s/'/\\\\'/g")
    fish -c "task-ai '$escaped'"
fi
